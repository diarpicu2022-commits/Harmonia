# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://harmonia-app.vercel.app
BACKEND_URL=https://harmonia-api.railway.app

# ─── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/harmonia

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ─── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx

# ─── YouTube Data API v3 ───────────────────────────────────────────────────────
YOUTUBE_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Spotify Web API ───────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SPOTIFY_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Groq (IA gratuita — sin tarjeta, 500k tokens/día) ────────────────────────
# Clave gratis en: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Optional: Redis cache ─────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
